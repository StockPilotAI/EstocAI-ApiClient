meta {
  name: list movements
  type: http
  seq: 3
}

get {
  url: {{apiUrl}}/api/v1/movements?inventoryId={{inventoryId}}&productId={{productId}}&movementType=ENTRADA
  body: none
  auth: none
}

params:query {
  inventoryId: {{inventoryId}}
  productId: {{productId}}
  startDate:
  endDate:
  movementType: ENTRADA
}

headers {
  X-User-Role: {{userRole}}
  Authorization: Bearer {{accessToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
