meta {
  name: create movement
  type: http
  seq: 1
}

post {
  url: {{apiUrl}}/api/v1/movements
  body: json
  auth: none
}

headers {
  X-User-Role: {{userRole}}
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "inventoryId": "{{inventoryId}}",
    "productId": "{{productId}}",
    "movementType": "ENTRADA",
    "quantity": 10,
    "totalValue": 299,
    "notes": "Entrada inicial"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
