meta {
  name: cancel movement
  type: http
  seq: 4
}

post {
  url: {{apiUrl}}/api/v1/movements/{{movementId}}/cancel
  body: json
  auth: none
}

headers {
  X-User-Role: {{userRole}}
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "reason": "Lancamento duplicado"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
