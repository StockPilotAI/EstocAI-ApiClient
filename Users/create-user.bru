meta {
  name: create user
  type: http
  seq: 1
}

post {
  url: {{apiUrl}}/api/v1/users
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
  X-User-Role: ADMIN
}

body:json {
  {
    "emailPrincipal": "joao.silva@example.com",
    "cpf": "11110111130",
    "password": "12345678",
    "tipoAcesso": "ADMIN"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
