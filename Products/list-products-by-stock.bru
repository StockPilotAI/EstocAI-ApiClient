meta {
  name: list products by stock
  type: http
  seq: 8
}

get {
  url: {{apiUrl}}/api/v1/products?page=1&limit=10
  body: none
  auth: none
}

params:query {
  page: 1
  limit: 10
  ~estoqueId: {{estoqueId}}
}

headers {
  Authorization: Bearer {{accessToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
