meta {
  name: update company
  type: http
  seq: 4
}

put {
  url: {{apiUrl}}/api/v1/companies/{{companyId}}
  body: json
  auth: none
}

headers {
  X-User-Role: {{userRole}}
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "tradeName": "EstocAI Labs",
    "phone": "11988887777"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
