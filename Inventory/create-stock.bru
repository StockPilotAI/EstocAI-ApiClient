meta {
  name: create stock
  type: http
  seq: 3
}

post {
  url: {{apiUrl}}/api/v1/stocks
  body: json
  auth: none
}

headers {
  X-User-Role: {{userRole}}
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "companyId": "{{companyId}}",
    "name": "Main Stock",
    "description": "Primary inventory",
    "location": "Warehouse A",
    "totalCapacity": 1000
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
