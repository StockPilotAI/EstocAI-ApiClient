meta {
  name: list stocks
  type: http
  seq: 5
}

get {
  url: {{apiUrl}}/api/v1/stocks?page=1&limit=10
  body: none
  auth: none
}

params:query {
  page: 1
  limit: 10
}

headers {
  X-User-Role: {{userRole}}
  Authorization: Bearer {{accessToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
