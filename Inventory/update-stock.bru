meta {
  name: update stock
  type: http
  seq: 7
}

put {
  url: {{apiUrl}}/api/v1/stocks/{{inventoryId}}
  body: json
  auth: none
}

headers {
  X-User-Role: {{userRole}}
  Authorization: Bearer {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "name": "Main Stock Updated",
    "description": "Updated primary inventory",
    "location": "Warehouse B",
    "totalCapacity": 1500
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
